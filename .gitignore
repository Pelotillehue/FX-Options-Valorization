# Entorno virtual
.venv/
venv/
env/

# Cache de Python
__pycache__/
*.py[cod]
*.egg-info/

# Datos de entrada (confidenciales: adjuntos del correo)
data/*
!data/.gitkeep

# Salidas generadas
salidas/*
!salidas/.gitkeep

# Archivos de mercado / cartera sueltos (por si quedan en la raíz)
*.xlsx
*.xlsm
*.csv

# Excepción: datos de mercado de prueba (no sensibles) sí se versionan
!tests/data/*.xlsx

# Sistema
.DS_Store
Thumbs.db
.vscode/
.idea/
